#!/usr/bin/env bash
# deadman — curses-like TUI multi-host liveness monitor (Bash reimplementation).
#
# Behaviour mirrors upa/deadman (https://github.com/upa/deadman), which itself
# originates from "pingman" by the Interop Tokyo ShowNet NOC team. This file
# is a clean-room reimplementation in Bash targeting macOS; it reads the same
# 'NAME  ADDRESS' config format and draws a similar dashboard.

set -u

export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

VERSION="[ver bash-1.0]"
HOSTNAME_SHORT="$(hostname -s 2>/dev/null || hostname)"

# -------- tunables --------
RTT_SCALE=10         # -s : ms per step of the RTT bar
RESULT_LEN=10        # how many recent probes to show per target
PING_TIMEOUT=1       # per-probe timeout in seconds
TICK=1               # seconds per cycle

CFG=""
LOGDIR=""

usage() {
  cat <<EOF
Usage: deadman [-s SCALE] [-a] [-b] [-l LOGDIR] [-h] configfile

  -s, --scale SCALE    milliseconds per step of the RTT bar (default: $RTT_SCALE)
  -a, --async-mode     accepted for compatibility (always async in this build)
  -b, --blink-arrow    accepted for compatibility (no-op)
  -l, --logging DIR    append per-target log lines into DIR
  -h, --help           show this help

Keys inside the TUI:
  q        quit
  r        refresh counters (reset history)

Signals:
  SIGHUP   reload the config file; history is preserved for existing targets
EOF
}

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      -s|--scale)        RTT_SCALE="$2"; shift 2 ;;
      -a|--async-mode)   shift ;;
      -b|--blink-arrow)  shift ;;
      -l|--logging)      LOGDIR="$2"; shift 2 ;;
      -h|--help)         usage; exit 0 ;;
      --)                shift; break ;;
      -*)                printf 'unknown option: %s\n' "$1" >&2; exit 2 ;;
      *)                 CFG="$1"; shift ;;
    esac
  done
  [[ -z "$CFG" ]]          && { usage >&2; exit 2; }
  [[ -r "$CFG" ]]          || { printf 'cannot read config: %s\n' "$CFG" >&2; exit 1; }
  [[ "$RTT_SCALE" =~ ^[0-9]+$ ]] || { printf 'invalid scale: %s\n' "$RTT_SCALE" >&2; exit 2; }
  [[ -n "$LOGDIR" ]] && { mkdir -p "$LOGDIR" || exit 1; }
}

# -------- colors --------
if [[ -t 1 ]]; then
  RED=$'\e[31m'; GREEN=$'\e[32m'; YELLOW=$'\e[33m'
  DIM=$'\e[2m';  BOLD=$'\e[1m';   RESET=$'\e[0m'
else
  RED=""; GREEN=""; YELLOW=""; DIM=""; BOLD=""; RESET=""
fi

# -------- terminal control --------
init_term()    { printf '\e[?1049h\e[?25l\e[2J\e[H'; }
restore_term() { printf '\e[?25h\e[?1049l'; }

# -------- state (parallel arrays, one slot per config line) --------
declare -a P_KIND P_NAME P_ADDR P_FAMILY
declare -a S_SNT S_LOSS S_TOT S_RTT S_AVG S_TTL S_STATE S_RESULT

append_slot() {
  P_KIND+=("$1"); P_NAME+=("$2"); P_ADDR+=("$3"); P_FAMILY+=("$4")
  S_SNT+=(0); S_LOSS+=(0); S_TOT+=(0); S_RTT+=(0)
  S_AVG+=(0); S_TTL+=(0); S_STATE+=(""); S_RESULT+=("")
}

ipfamily() {
  case "$1" in
    *:*) echo 6 ;;
    *)   echo 4 ;;
  esac
}

load_config() {
  local -a O_KIND=() O_NAME=() O_ADDR=()
  local -a O_SNT=() O_LOSS=() O_TOT=() O_RTT=() O_AVG=() O_TTL=() O_STATE=() O_RESULT=()
  local i
  for i in "${!P_KIND[@]}"; do
    O_KIND[i]="${P_KIND[i]}"; O_NAME[i]="${P_NAME[i]}"; O_ADDR[i]="${P_ADDR[i]}"
    O_SNT[i]="${S_SNT[i]}";   O_LOSS[i]="${S_LOSS[i]}"; O_TOT[i]="${S_TOT[i]}"
    O_RTT[i]="${S_RTT[i]}";   O_AVG[i]="${S_AVG[i]}";   O_TTL[i]="${S_TTL[i]}"
    O_STATE[i]="${S_STATE[i]}"; O_RESULT[i]="${S_RESULT[i]}"
  done

  P_KIND=(); P_NAME=(); P_ADDR=(); P_FAMILY=()
  S_SNT=(); S_LOSS=(); S_TOT=(); S_RTT=(); S_AVG=(); S_TTL=(); S_STATE=(); S_RESULT=()

  local line name addr fields
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^[[:space:]]*---[[:space:]]*$ ]]; then
      append_slot "s" "" "" ""
      continue
    fi
    read -ra fields <<<"$line"
    name="${fields[0]:-}"
    addr="${fields[1]:-}"
    [[ -z "$addr" ]] && continue
    append_slot "t" "$name" "$addr" "$(ipfamily "$addr")"
    local idx=$(( ${#P_KIND[@]} - 1 ))
    local j
    for j in "${!O_KIND[@]}"; do
      if [[ "${O_KIND[j]:-}" == "t" && "${O_NAME[j]:-}" == "$name" && "${O_ADDR[j]:-}" == "$addr" ]]; then
        S_SNT[idx]="${O_SNT[j]}";   S_LOSS[idx]="${O_LOSS[j]}"; S_TOT[idx]="${O_TOT[j]}"
        S_RTT[idx]="${O_RTT[j]}";   S_AVG[idx]="${O_AVG[j]}";   S_TTL[idx]="${O_TTL[j]}"
        S_STATE[idx]="${O_STATE[j]}"; S_RESULT[idx]="${O_RESULT[j]}"
        break
      fi
    done
  done < "$CFG"
}

# -------- ping --------

# Echoes "OK <int_ms> <ttl>" on success, "FAIL" otherwise.
do_ping() {
  local addr="$1" family="$2"
  local -a cmd
  if [[ "$family" == "6" ]]; then
    if command -v ping6 >/dev/null 2>&1; then
      cmd=(ping6 -c 1 "$addr")
    else
      cmd=(ping -6 -c 1 -W "${PING_TIMEOUT}000" "$addr")
    fi
  else
    cmd=(ping -c 1 -W "${PING_TIMEOUT}000" -t "$PING_TIMEOUT" "$addr")
  fi
  local out
  out=$(LC_ALL=C "${cmd[@]}" 2>/dev/null)
  if [[ ! "$out" =~ time=([0-9]+(\.[0-9]+)?) ]]; then
    echo "FAIL"
    return
  fi
  local rtt="${BASH_REMATCH[1]}" ms
  ms=$(awk -v r="$rtt" 'BEGIN { printf "%d", r + 0.5 }')
  local ttl="-1"
  [[ "$out" =~ (ttl|hlim)=([0-9]+) ]] && ttl="${BASH_REMATCH[2]}"
  echo "OK $ms $ttl"
}

fire_pings() {
  local tmpdir="$1" i
  for i in "${!P_KIND[@]}"; do
    [[ "${P_KIND[i]}" == "t" ]] || continue
    ( do_ping "${P_ADDR[i]}" "${P_FAMILY[i]}" >"$tmpdir/$i" ) &
  done
  wait
}

bar_char() {
  local ms="$1"
  if   (( ms < RTT_SCALE * 1 )); then echo "▁"
  elif (( ms < RTT_SCALE * 2 )); then echo "▂"
  elif (( ms < RTT_SCALE * 3 )); then echo "▃"
  elif (( ms < RTT_SCALE * 4 )); then echo "▄"
  elif (( ms < RTT_SCALE * 5 )); then echo "▅"
  elif (( ms < RTT_SCALE * 6 )); then echo "▆"
  elif (( ms < RTT_SCALE * 7 )); then echo "▇"
  else                                echo "█"
  fi
}

collect_results() {
  local tmpdir="$1" i res rtt ttl ts
  ts="$(date '+%Y-%m-%dT%H:%M:%S%z')"
  for i in "${!P_KIND[@]}"; do
    [[ "${P_KIND[i]}" == "t" ]] || continue
    if [[ -f "$tmpdir/$i" ]]; then
      res=$(<"$tmpdir/$i")
    else
      res="FAIL"
    fi
    S_SNT[i]=$(( S_SNT[i] + 1 ))
    if [[ "$res" == OK* ]]; then
      read -r _ rtt ttl <<<"$res"
      S_STATE[i]="up"
      S_RTT[i]="$rtt"
      S_TOT[i]=$(( S_TOT[i] + rtt ))
      S_AVG[i]=$(( S_TOT[i] / S_SNT[i] ))
      S_TTL[i]="$ttl"
      S_RESULT[i]="$(bar_char "$rtt")${S_RESULT[i]}"
      [[ -n "$LOGDIR" ]] && printf '%s OK rtt=%sms ttl=%s\n' "$ts" "$rtt" "$ttl" \
        >> "$LOGDIR/${P_NAME[i]}.log"
    else
      S_STATE[i]="down"
      S_LOSS[i]=$(( S_LOSS[i] + 1 ))
      S_RESULT[i]="X${S_RESULT[i]}"
      [[ -n "$LOGDIR" ]] && printf '%s FAIL\n' "$ts" >> "$LOGDIR/${P_NAME[i]}.log"
    fi
    local r="${S_RESULT[i]}"
    (( ${#r} > RESULT_LEN )) && S_RESULT[i]="${r:0:RESULT_LEN}"
  done
}

refresh_all() {
  local i
  for i in "${!P_KIND[@]}"; do
    S_SNT[i]=0; S_LOSS[i]=0; S_TOT[i]=0; S_RTT[i]=0
    S_AVG[i]=0; S_TTL[i]=0; S_STATE[i]=""; S_RESULT[i]=""
  done
}

repeat_char() {
  local n="$1" ch="$2" out=""
  (( n <= 0 )) && { echo ""; return; }
  local k
  for ((k=0; k<n; k++)); do out+="$ch"; done
  echo "$out"
}

render() {
  local cols
  cols=$(tput cols 2>/dev/null || echo 80)
  local buf=$'\e[H'

  local title="Dead Man"
  local title_pad=$(( (cols - ${#title}) / 2 ))
  (( title_pad < 0 )) && title_pad=0
  local right_space=$(( cols - title_pad - ${#title} - ${#VERSION} - 1 ))
  (( right_space < 1 )) && right_space=1
  local line1
  printf -v line1 "%*s${BOLD}%s${RESET}%*s%s" \
    "$title_pad" "" "$title" "$right_space" "" "$VERSION"
  buf+="${line1}"$'\e[K\n'

  buf+=" From: $HOSTNAME_SHORT"$'\e[K\n'
  buf+=" RTT Scale ${RTT_SCALE}ms. Keys: (q)uit (r)efresh"$'\e[K\n'
  buf+=$'\e[K\n'

  local hdr
  printf -v hdr " %-20s %-22s %4s %4s %4s %4s %s" \
    "HOSTNAME" "ADDRESS" "LOSS" "RTT" "AVG" "SNT" "RESULT"
  buf+="${BOLD}${hdr}${RESET}"$'\e[K\n'

  local i color state snt loss rtt avg lossrate row sep
  for i in "${!P_KIND[@]}"; do
    if [[ "${P_KIND[i]}" == "s" ]]; then
      sep=$(repeat_char "$(( cols - 2 ))" "─")
      buf+=" ${DIM}${sep}${RESET}"$'\e[K\n'
      continue
    fi
    snt=${S_SNT[i]}; loss=${S_LOSS[i]}; rtt=${S_RTT[i]}; avg=${S_AVG[i]}
    state=${S_STATE[i]}
    lossrate=0
    (( snt > 0 )) && lossrate=$(( loss * 100 / snt ))
    color="$RESET"
    [[ "$state" == "up"   ]] && color="$GREEN"
    [[ "$state" == "down" ]] && color="$RED"
    printf -v row " %-20s %-22s %3d%% %4d %4d %4d %s" \
      "${P_NAME[i]}" "${P_ADDR[i]}" "$lossrate" "$rtt" "$avg" "$snt" "${S_RESULT[i]}"
    buf+="${color}${row}${RESET}"$'\e[K\n'
  done
  buf+=$'\e[J'
  printf '%s' "$buf"
}

cleanup() {
  restore_term
  [[ -n "${WORKDIR:-}" && -d "$WORKDIR" ]] && rm -rf "$WORKDIR"
}

RELOAD=0
RUNNING=1

on_hup()  { RELOAD=1; }
on_stop() { RUNNING=0; }

main() {
  parse_args "$@"
  WORKDIR=$(mktemp -d -t deadman.XXXXXX) || exit 1
  init_term
  trap cleanup EXIT
  trap on_hup HUP
  trap on_stop INT TERM

  load_config
  render

  while (( RUNNING )); do
    fire_pings "$WORKDIR"
    collect_results "$WORKDIR"
    render
    local key=""
    if IFS= read -rsn1 -t "$TICK" key 2>/dev/null; then
      case "$key" in
        q|Q) RUNNING=0 ;;
        r|R) refresh_all ;;
      esac
    fi
    if (( RELOAD )); then
      RELOAD=0
      load_config
    fi
  done
}

main "$@"
