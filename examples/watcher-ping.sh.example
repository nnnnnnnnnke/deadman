#!/usr/bin/env bash
# deadman watcher (ICMP)
# ----------------------
# Ping one or more target hosts/IPs. If any is reachable, call 'deadman ping'
# so the deadman timer resets.  Run this periodically via launchd (every
# minute or so) — see examples/com.deadman.watcher.plist.example.
#
# Copy to ~/bin/deadman-watcher.sh, edit TARGETS, then make it executable:
#   cp examples/watcher-ping.sh.example ~/bin/deadman-watcher.sh
#   chmod +x ~/bin/deadman-watcher.sh

set -euo pipefail

# Targets to monitor. The first one that responds wins.
# Use IP addresses or hostnames.
TARGETS=(
  "192.168.1.1"
  "example.com"
)

# Path to the deadman binary. Launchd has a minimal PATH, so prefer absolute.
DEADMAN_BIN="${DEADMAN_BIN:-$(command -v deadman 2>/dev/null || echo /usr/local/bin/deadman)}"

for t in "${TARGETS[@]}"; do
  # -c 1: one packet   -W 2000: wait up to 2000ms   -q: quiet
  if ping -c 1 -W 2000 -q "$t" > /dev/null 2>&1; then
    "$DEADMAN_BIN" ping > /dev/null
    echo "reachable: $t — deadman pinged"
    exit 0
  fi
done

echo "no target reachable" >&2
exit 1
