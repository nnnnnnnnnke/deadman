#!/usr/bin/env bash
# Example deadman trigger: local notification + email via the macOS 'mail' command.
#
# Copy to ~/bin/deadman-panic.sh and customize, then register with:
#   deadman config set trigger_script ~/bin/deadman-panic.sh

set -euo pipefail

RECIPIENT="you@example.com"
HOSTNAME="$(hostname)"
LAST_PING_HUMAN="$(date -r "${DEADMAN_LAST_PING:-0}" '+%Y-%m-%d %H:%M:%S %z' 2>/dev/null || echo unknown)"

# 1) Local notification (you must be logged in to see it)
osascript -e "display notification \"deadman fired on $HOSTNAME\" with title \"DEADMAN\""

# 2) Send email via the 'mail' command (requires sendmail / postfix configured)
SUBJECT="[deadman] $HOSTNAME has not checked in"
BODY="deadman timer expired.

host:         $HOSTNAME
last ping:    $LAST_PING_HUMAN
timeout (s):  ${DEADMAN_TIMEOUT:-?}
elapsed (s):  ${DEADMAN_ELAPSED:-?}
fired at:     $(date '+%Y-%m-%d %H:%M:%S %z')
test mode:    ${DEADMAN_TEST:-0}
"

echo "$BODY" | mail -s "$SUBJECT" "$RECIPIENT"
