<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd agent template for the deadman watcher.

  1. Copy this file to ~/Library/LaunchAgents/com.deadman.watcher.plist
  2. Replace __USER__ with your macOS username (or just use an absolute path)
  3. Ensure the watcher script path matches where you installed it
  4. Load it:
       launchctl load ~/Library/LaunchAgents/com.deadman.watcher.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.deadman.watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/__USER__/bin/deadman-watcher.sh</string>
    </array>

    <!-- How often to probe the target(s), in seconds -->
    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <true/>

    <!-- launchd has a minimal PATH; ensure deadman is findable -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/__USER__/.local/state/deadman/watcher.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/__USER__/.local/state/deadman/watcher.err.log</string>
</dict>
</plist>
