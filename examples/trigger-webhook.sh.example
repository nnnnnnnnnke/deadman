#!/usr/bin/env bash
# Example deadman trigger: POST to a Slack/Discord-compatible webhook.
#
# Store the webhook URL in macOS Keychain rather than hard-coding it here:
#   security add-generic-password -a "$USER" -s deadman-webhook -w 'https://hooks.slack.com/...'
#
# Then register this script:
#   deadman config set trigger_script ~/bin/deadman-panic.sh

set -euo pipefail

WEBHOOK_URL="$(security find-generic-password -a "$USER" -s deadman-webhook -w)"
HOSTNAME="$(hostname)"
LAST_PING_HUMAN="$(date -r "${DEADMAN_LAST_PING:-0}" '+%Y-%m-%d %H:%M:%S %z' 2>/dev/null || echo unknown)"

TEXT=":rotating_light: *deadman fired*
- host: \`$HOSTNAME\`
- last ping: $LAST_PING_HUMAN
- elapsed: ${DEADMAN_ELAPSED:-?}s / timeout: ${DEADMAN_TIMEOUT:-?}s
- test mode: ${DEADMAN_TEST:-0}"

# Slack-compatible payload. For Discord, change "text" to "content".
PAYLOAD=$(cat <<EOF
{"text": $(printf '%s' "$TEXT" | python3 -c 'import json,sys;print(json.dumps(sys.stdin.read()))')}
EOF
)

curl -fsS -X POST -H 'Content-Type: application/json' \
  --data "$PAYLOAD" \
  "$WEBHOOK_URL"
