#!/usr/bin/env bash
# deadman watcher (HTTP)
# ----------------------
# Hit one or more HTTP endpoints. If any returns 2xx, call 'deadman ping'
# so the deadman timer resets. Run this periodically via launchd — see
# examples/com.deadman.watcher.plist.example.
#
# Copy to ~/bin/deadman-watcher.sh, edit TARGETS, then make executable:
#   cp examples/watcher-http.sh.example ~/bin/deadman-watcher.sh
#   chmod +x ~/bin/deadman-watcher.sh

set -euo pipefail

# Health-check URLs. First 2xx wins.
TARGETS=(
  "https://example.com/health"
  "https://www.google.com/"
)

DEADMAN_BIN="${DEADMAN_BIN:-$(command -v deadman 2>/dev/null || echo /usr/local/bin/deadman)}"

for url in "${TARGETS[@]}"; do
  if curl -fsS --max-time 5 -o /dev/null "$url"; then
    "$DEADMAN_BIN" ping > /dev/null
    echo "reachable: $url — deadman pinged"
    exit 0
  fi
done

echo "no target reachable" >&2
exit 1
