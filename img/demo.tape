# VHS tape to generate img/deadman-demo.gif
# Regenerate with:  vhs img/demo.tape

Output img/deadman-demo.gif

Set Shell "bash"
Set FontSize 14
Set Width  1200
Set Height 640
Set Padding 12
Set TypingSpeed 45ms
Set Theme "Builtin Dark"

Type "./deadman -a myconf"
Enter
Sleep 18s
Type "q"
Sleep 500ms
